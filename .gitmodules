[submodule "vim/.vim/vim-plug"]
	path = vim/.vim/vim-plug
	url = git@github.com:junegunn/vim-plug.git
[submodule "zsh/oh-my-zsh"]
	path = zsh/oh-my-zsh
	url = git@github.com:ohmyzsh/ohmyzsh.git
[submodule "zsh/custom/zsh-syntax-highlighting"]
	path = zsh/custom/zsh-syntax-highlighting
	url = git@github.com:zsh-users/zsh-syntax-highlighting.git
[submodule "bat/themes/Everblush"]
	path = bat/themes/Everblush
	url = git@github.com:Everblush/bat.git
