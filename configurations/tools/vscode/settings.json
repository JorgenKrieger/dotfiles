{
    // VSCode Theme
    "workbench.colorTheme": "Monokai Pro",

    // Editor settings
    "editor.fontFamily": "'Operator Mono', Menlo, Monaco, 'Courier New', monospace",
    "editor.fontSize": 16,
    "editor.fontWeight": "400",
    "editor.fontLigatures": true,
    "editor.letterSpacing": 0.2,
    "editor.lineHeight": 32,
    
    "editor.cursorStyle": "line",
    "editor.cursorWidth": 5,
    "editor.cursorBlinking": "phase",
    "editor.insertSpaces": true,
    "editor.tabSize": 4,
    "editor.renderWhitespace": "none",
    "editor.renderIndentGuides": false,
    "editor.quickSuggestions": false,
    
    "emmet.showExpandedAbbreviation": "never",
    "emmet.triggerExpansionOnTab": true,

    "files.watcherExclude": {
        "**": true
    },
    "files.useExperimentalFileWatcher": false,

    "window.zoomLevel": 1,

    // Explorer settings
    "explorer.openEditors.visible": 0,
    "workbench.tree.indent": 22,
    "workbench.iconTheme": "ayu",
    "files.exclude": {
        "**/.pnp.js": true,
        "**/.yarn/": true,
    },

    // Terminal settings
    "terminal.integrated.fontFamily": "'OperatorMono Nerd Font",
    "terminal.integrated.fontSize": 12,
    "terminal.integrated.lineHeight": 1.25,
    "terminal.integrated.shell.osx": "/bin/zsh",

    // Entensions
    "extensions.showRecommendationsOnlyOnDemand": true,

    // Extension: Colorize
    "colorize.languages": [
        "javascript",
        "json",
        "css",
        "sass",
        "scss",
        "xml",
        "svg"
    ],
    "colorize.colorized_variables": [
        "CSS",
        "LESS",
        "SASS",
        "STYLUS"
    ],
    "colorize.enable_search_variables": true,

    // Extension: ESLint
    "eslint.enable": true,

    // Extension: Bracket Pair Colorizer
    "bracketPairColorizer.showVerticalScopeLine": false,

    // Extension: Vim
    "vim.history": 1000,
    "vim.hlsearch": true,
    "vim.insertModeKeyBindings": [
        {
            "before": ["i", "i"],
            "after": ["<Esc>"]
        }
    ],
    "vim.easymotion": true,
    "vim.sneak": true,
    "vim.incsearch": true,
    "vim.useSystemClipboard": true,
    "vim.useCtrlKeys": true,

    // Extension: Auto Close Tag
    "auto-close-tag.activationOnLanguage": [
        "xml",
        "php",
        "blade",
        "ejs",
        "jinja",
        "javascriptreact",
        "typescriptreact",
        "plaintext",
        "markdown",
        "vue",
        "liquid",
        "erb",
        "lang-cfml",
        "cfml",
        "HTML (Eex)"
    ],

    "customizeUI.activityBar": "bottom", // Options: wide, bottom
    "customizeUI.titleBar": "frameless", // Options: inline, frameless
    "window.titleBarStyle": "native",

    "customizeUI.stylesheet": {
        //".monaco-workbench, .monaco-workbench .sidebar, .monaco-workbench .activitybar, .monaco-workbench .titlebar, .monaco-workbench .monaco-list-rows, body": "background: transparent !important;"
    },
    "customizeUI.listRowHeight": 24,

    "disableLigatures.mode": "Cursor",
    "breadcrumbs.enabled": false,
    "workbench.activityBar.visible": true,
    "workbench.statusBar.visible": false


}